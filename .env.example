# ─── App ports ────────────────────────────────────────────────────────────────
# Shared bearer token required by the web UI and all tRPC calls.
# Generate with: openssl rand -hex 32
DEVLET_AUTH_TOKEN=replace-with-a-long-random-token
# Host port for the API server (default: 3001)
SERVER_PORT=3001
# Host port for the web UI (default: 3000)
WEB_PORT=3000
# Public base URL users access Devlet through.
# Use http://localhost:3000 for local dev, or your HTTPS/Tailscale URL in shared environments.
DEVLET_PUBLIC_BASE_URL=http://localhost:3000
# Optional: one or more SSH public keys for direct agent SSH access.
# Separate multiple keys with literal \n characters if you keep them on one line.
# DEVLET_AGENT_SSH_AUTHORIZED_KEYS=ssh-ed25519 AAAAC3Nza... you@host
# Published app image to run for the server container
SERVER_IMAGE=ghcr.io/your-org/devlet-server:sha-<commit>
# Published app image to run for the web container
WEB_IMAGE=ghcr.io/your-org/devlet-web:sha-<commit>

# ─── Portainer ────────────────────────────────────────────────────────────────
# URL of your existing Portainer instance — no trailing slash
PORTAINER_URL=http://portainer.example.com:9000
# API key — create one in Portainer → Account Settings → Access Tokens
PORTAINER_API_KEY=ptr_xxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: comma-separated endpoint IDs or names to exclude from scheduling
# PORTAINER_EXCLUDED_ENDPOINTS=1,gpu-lab,staging-swarm

# ─── Proxmox ──────────────────────────────────────────────────────────────────
# URL of your Proxmox VE API — no trailing slash
PROXMOX_URL=https://proxmox.example.com:8006
# User in user@realm format
PROXMOX_USER=root@pam
# API token name (the part after the !)
# Create via: Datacenter → Permissions → API Tokens → Add
PROXMOX_TOKEN_ID=devlet
# API token secret UUID
PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Set to "true" to skip TLS verification (for self-signed certs)
PROXMOX_INSECURE=false
# Optional: comma-separated Proxmox node names to exclude from scheduling
# PROXMOX_EXCLUDED_NODES=pve-test,pve-gpu-02
# Default node to schedule agents on (must exist in your cluster)
PROXMOX_NODE=pve
# Storage pool for VM/LXC disks
PROXMOX_STORAGE=local-lvm
# LXC OS template path (e.g. local:vztmpl/debian-12-standard_12.2-1_amd64.tar.zst)
PROXMOX_LXC_TEMPLATE=
# QEMU template VM ID to clone for GPU agents (0 = not configured)
PROXMOX_QEMU_TEMPLATE_ID=0

# ─── Providers ────────────────────────────────────────────────────────────────
# API keys forwarded automatically to every agent container the server spawns.
# Agents that don't need a given key ignore it.
# Per-agent env vars set at hire time take precedence over these platform defaults.
ANTHROPIC_API_KEY=sk-ant-xxxx
OPENAI_API_KEY=sk-xxxx
GEMINI_API_KEY=AIzaxxxx
OPENROUTER_API_KEY=sk-or-xxxx
LITELLM_BASE_URL=https://litellm.example.com
LITELLM_API_KEY=sk-xxxx
# DEVLET_OPENCLAW_AUTO_PAIR=true   # dev/home-lab only: auto-approves pending OpenClaw device pair requests
# NVIDIA_API_KEY=nvapi-xxxx   # build.nvidia.com — OpenAI-compatible at integrate.api.nvidia.com/v1
# GROQ_API_KEY=gsk_xxxx
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# OPENAI_BASE_URL=https://api.openai.com/v1
# FIRECRAWL_API_KEY=fc-xxxx    # used by Hermes for web scraping
# TAVILY_API_KEY=tvly-xxxx     # used by Hermes for web search

# ─── Agent container images ───────────────────────────────────────────────────
# Override the Docker image used for each agent type.
# For public registries, prefer pinned ghcr.io tags or digests.
# AGENT_IMAGE_CLAUDE_CODE=ghcr.io/your-org/devlet-agent-base:sha-<commit>
# AGENT_IMAGE_CODEX=ghcr.io/your-org/devlet-agent-base:sha-<commit>
# AGENT_IMAGE_OPENCODE=ghcr.io/your-org/devlet-agent-base:sha-<commit>
# AGENT_IMAGE_PI=ghcr.io/your-org/devlet-agent-base:sha-<commit>
# AGENT_IMAGE_GEMINI=ghcr.io/your-org/devlet-agent-base:sha-<commit>
# AGENT_IMAGE_OPENCLAW=ghcr.io/your-org/devlet-agent-openclaw:sha-<commit>
# AGENT_IMAGE_NANOCLAW=ghcr.io/your-org/devlet-agent-nanoclaw:sha-<commit>
# AGENT_IMAGE_HERMES=ghcr.io/your-org/devlet-agent-hermes:sha-<commit>
# AGENT_IMAGE_MOLTIS=ghcr.io/your-org/devlet-agent-moltis:sha-<commit>
# AGENT_IMAGE_NEMOCLAW=node:22.22.2-slim
