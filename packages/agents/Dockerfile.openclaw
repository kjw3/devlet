# ── devlet/agent-openclaw ─────────────────────────────────────────────────────
# Built on the official OpenClaw image (ghcr.io/openclaw/openclaw).
#
# Required env at runtime (forwarded by devlet server):
#   DEVLET_AGENT_NAME       — propagated to agent identity + UI name
#   DEVLET_AGENT_ROLE       — written into SOUL.md persona
#   DEVLET_AGENT_MISSION    — written into AGENTS.md instructions
#   DEVLET_AGENT_PROVIDER   — anthropic | openai | litellm | etc.
#   DEVLET_AGENT_MODEL      — e.g. claude-sonnet-4-6
#   OPENCLAW_GATEWAY_TOKEN  — pre-generated by devlet server; auto-UUID fallback
#   OPENCLAW_HOST_PORT      — host-side port allocated by devlet server
#   ANTHROPIC_API_KEY / OPENAI_API_KEY / etc.
# ──────────────────────────────────────────────────────────────────────────────

ARG BASE_AGENT_IMAGE=devlet/agent-base:latest
FROM ${BASE_AGENT_IMAGE}

ARG OPENCLAW_VERSION=2026.4.11
ARG VCS_REF=unknown
ARG BUILD_DATE=unknown
ARG VERSION=0.1.0
ARG REPOSITORY_URL=https://github.com/kjw3/devlet

USER root

RUN npm install -g openclaw@${OPENCLAW_VERSION}

COPY packages/agents/entrypoint.openclaw.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 18789

LABEL org.opencontainers.image.title="devlet-agent-openclaw"
LABEL org.opencontainers.image.description="OpenClaw gateway preconfigured by devlet"
LABEL org.opencontainers.image.source="${REPOSITORY_URL}"
LABEL org.opencontainers.image.revision="${VCS_REF}"
LABEL org.opencontainers.image.created="${BUILD_DATE}"
LABEL org.opencontainers.image.version="${VERSION}"
LABEL devlet.agent.type="openclaw"

ENTRYPOINT ["/entrypoint.sh"]
CMD []
