# ── devlet/agent-hermes ───────────────────────────────────────────────────────
# Hermes (Nous Research) autonomous agent layered onto devlet/agent-base.
#
# Strategy: mirrors the official Hermes Dockerfile approach — clone source,
# install with uv — but builds on devlet/agent-base so all coding CLIs are
# included. uv binary pulled from Astral's image.
#
# Required env at runtime:
#   ANTHROPIC_API_KEY / OPENAI_API_KEY / OPENROUTER_API_KEY
# Optional:
#   DEVLET_AGENT_MODEL    - model to use
#   DEVLET_AGENT_MISSION  - task to run headlessly
#   GROQ_API_KEY          - Whisper STT
#   FIRECRAWL_API_KEY / TAVILY_API_KEY - web search
# ──────────────────────────────────────────────────────────────────────────────

ARG UV_IMAGE=ghcr.io/astral-sh/uv:0.9.30
ARG BASE_AGENT_IMAGE=devlet/agent-base:latest
FROM ${UV_IMAGE} AS uv_source

FROM ${BASE_AGENT_IMAGE}

ARG HERMES_REF=v2026.4.8
ARG VCS_REF=unknown
ARG BUILD_DATE=unknown
ARG VERSION=0.1.0
ARG REPOSITORY_URL=https://github.com/kjw3/devlet

USER root

# System deps from the official Hermes Dockerfile
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-dev libffi-dev build-essential gcc ripgrep ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# Install uv (Astral Python package manager used by Hermes)
COPY --from=uv_source /uv /usr/local/bin/uv

# Clone Hermes source and set ownership
RUN git clone --depth 1 --branch ${HERMES_REF} https://github.com/NousResearch/hermes-agent /opt/hermes && \
    chown -R agent:agent /opt/hermes

# Create hermes data/config dir
RUN mkdir -p /home/agent/.hermes && chown -R agent:agent /home/agent/.hermes

USER agent
WORKDIR /opt/hermes

# Install Hermes Python deps into a venv (same as official Dockerfile)
RUN uv venv && uv pip install --no-cache-dir -e ".[all]"

USER root
# Expose venv hermes bin on PATH
RUN ln -sf /opt/hermes/.venv/bin/hermes /usr/local/bin/hermes

COPY packages/agents/entrypoint.hermes.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENV HERMES_HOME=/home/agent/.hermes
ENV DISABLE_AUTOUPDATER=1
ENV CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

USER agent
WORKDIR /workspace

LABEL org.opencontainers.image.title="devlet-agent-hermes"
LABEL org.opencontainers.image.description="Hermes autonomous agent + devlet base coding agents (claude-code, codex, opencode, pi, gemini)"
LABEL org.opencontainers.image.source="${REPOSITORY_URL}"
LABEL org.opencontainers.image.revision="${VCS_REF}"
LABEL org.opencontainers.image.created="${BUILD_DATE}"
LABEL org.opencontainers.image.version="${VERSION}"
LABEL devlet.agent.type="hermes"

ENTRYPOINT ["/entrypoint.sh"]
CMD []
