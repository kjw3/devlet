# ── devlet/agent-base ─────────────────────────────────────────────────────────
# All base coding agents in one image.
# Select which agent runs via DEVLET_AGENT_TYPE at container start.
#
# Agents: claude-code | codex | opencode | pi | gemini
#
# Build args (pin versions):
#   CLAUDE_CODE_VERSION, CODEX_VERSION, OPENCODE_VERSION, PI_VERSION,
#   GEMINI_VERSION
#
# Required env at runtime:
#   DEVLET_AGENT_TYPE     - which agent to invoke
#   ANTHROPIC_API_KEY     - for claude-code / opencode(anthropic)
#   OPENAI_API_KEY        - for codex / opencode(openai)
#   GEMINI_API_KEY        - for gemini
# Optional:
#   DEVLET_AGENT_PROVIDER - anthropic | openai | google | litellm
#   DEVLET_AGENT_MODEL    - override model
#   DEVLET_AGENT_MISSION  - task to run headlessly (omit for interactive)
#   LITELLM_BASE_URL / LITELLM_API_KEY
#   DEVLET_AGENT_ID / DEVLET_API_URL / DEVLET_API_TOKEN
# ──────────────────────────────────────────────────────────────────────────────

ARG NODE_IMAGE=node:22.22.2-slim
FROM ${NODE_IMAGE}

ARG PNPM_VERSION=10.33.0
ARG TTYD_VERSION=1.7.7
ARG CLAUDE_CODE_VERSION=2.1.104
ARG CODEX_VERSION=0.120.0
ARG OPENCODE_VERSION=1.4.3
ARG PI_VERSION=0.66.1
ARG GEMINI_VERSION=0.37.1
ARG VCS_REF=unknown
ARG BUILD_DATE=unknown
ARG VERSION=0.1.0
ARG REPOSITORY_URL=https://github.com/kjw3/devlet

# System dependencies
# Notes on specific packages:
#   ripgrep   — claude-code/opencode explicitly prefer `rg` for code search over grep
#   fd-find   — fast file finder (binary: `fdfind`); claude-code uses it for directory traversal
#   jq        — agents frequently shell out to `jq` for JSON processing in scripts/tool calls
#   python3   — many agent helper scripts and tool invocations assume python3 is available
#   openssh-client — required for git operations over SSH to remote repositories
#   openssh-server — enables Devlet-managed SSH access for IDEs/debugging
#   less      — pager; some TUI tools (including agent subprocesses) fail without it
#   make      — needed for projects with Makefiles and some npm package postinstall scripts
#
#   bubblewrap intentionally omitted: bwrap requires SYS_ADMIN/user-namespaces which are
#   not available in standard (non-privileged) Docker containers. The --dangerously-bypass
#   flags already used in the entrypoint are the correct approach for containerized agents.
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates bash procps \
    ripgrep fd-find jq python3 openssh-client openssh-server less make \
    && rm -rf /var/lib/apt/lists/* \
    && ln -s /usr/bin/fdfind /usr/local/bin/fd

# Install ttyd static binary — web terminal (multi-arch: x86_64 / aarch64)
RUN set -eux; \
    ARCH="$(uname -m)"; \
    case "$ARCH" in \
      x86_64)  TTYD_ARCH="x86_64"  ;; \
      aarch64) TTYD_ARCH="aarch64" ;; \
      *) echo "Unsupported arch: $ARCH" && exit 1 ;; \
    esac; \
    curl -fsSL \
      --retry 10 \
      --retry-delay 2 \
      --retry-max-time 120 \
      --retry-all-errors \
      "https://github.com/tsl0922/ttyd/releases/download/${TTYD_VERSION}/ttyd.${TTYD_ARCH}" \
      -o /usr/local/bin/ttyd && \
    chmod +x /usr/local/bin/ttyd

# Install all base coding agents
RUN npm install -g pnpm@${PNPM_VERSION} \
    @anthropic-ai/claude-code@${CLAUDE_CODE_VERSION} \
    @openai/codex@${CODEX_VERSION} \
    opencode-ai@${OPENCODE_VERSION} \
    @mariozechner/pi-coding-agent@${PI_VERSION} \
    @google/gemini-cli@${GEMINI_VERSION}

# Disable auto-updater and telemetry in container context
ENV DISABLE_AUTOUPDATER=1
ENV CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
ENV DEVLET_AGENT_TYPE=claude-code

COPY packages/agents/entrypoint.base.sh /entrypoint.sh
COPY packages/agents/devlet-terminal.sh /usr/local/bin/devlet-terminal
COPY packages/agents/devlet-ssh.sh /usr/local/bin/devlet-ssh
COPY packages/agents/devlet-coding-init.sh /usr/local/bin/devlet-coding-init
RUN chmod +x /entrypoint.sh /usr/local/bin/devlet-terminal /usr/local/bin/devlet-ssh /usr/local/bin/devlet-coding-init

# Create non-root agent user — coding agents refuse --dangerously-skip-permissions as root
RUN useradd --create-home --user-group --shell /bin/bash agent && \
    mkdir -p /workspace && chown agent:agent /workspace

USER agent
WORKDIR /workspace

LABEL org.opencontainers.image.title="devlet-agent-base"
LABEL org.opencontainers.image.description="Base coding agent image: claude-code, codex, opencode, pi, gemini"
LABEL org.opencontainers.image.source="${REPOSITORY_URL}"
LABEL org.opencontainers.image.revision="${VCS_REF}"
LABEL org.opencontainers.image.created="${BUILD_DATE}"
LABEL org.opencontainers.image.version="${VERSION}"
LABEL devlet.agent.type="base"

ENTRYPOINT ["/entrypoint.sh"]
CMD []
