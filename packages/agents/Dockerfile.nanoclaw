# ── devlet/agent-nanoclaw ─────────────────────────────────────────────────────
# NanoClaw (qwibitai) + all base coding agents via devlet/agent-base.
# NanoClaw is built on Anthropic's Agents SDK with Claude Code as orchestrator.
# Assistant trigger word defaults to "@Andy" (override via ASSISTANT_NAME).
#
# Required env at runtime:
#   ANTHROPIC_API_KEY     - NanoClaw requires Anthropic
# Optional:
#   ANTHROPIC_BASE_URL    - custom API endpoint / proxy
#   ASSISTANT_NAME        - trigger word (default: @Andy)
#   OPENAI_API_KEY        - for codex / opencode(openai)
#   GEMINI_API_KEY        - for gemini
#   DEVLET_AGENT_MISSION  - task to run headlessly
#   DEVLET_AGENT_ID / DEVLET_API_URL / DEVLET_API_TOKEN
# ──────────────────────────────────────────────────────────────────────────────

ARG BASE_AGENT_IMAGE=devlet/agent-base:latest
FROM ${BASE_AGENT_IMAGE}

ARG NANOCLAW_REF=v0.9.10
ARG VCS_REF=unknown
ARG BUILD_DATE=unknown
ARG VERSION=0.1.0
ARG REPOSITORY_URL=https://github.com/kjw3/devlet

# Root needed to clone into / and install entrypoint; agent-base sets USER agent
USER root

RUN (git clone --depth 1 --branch ${NANOCLAW_REF} \
    https://github.com/qwibitai/nanoclaw /nanoclaw 2>/dev/null || \
    git clone --depth 1 https://github.com/qwibitai/nanoclaw /nanoclaw) && \
    chown -R agent:agent /nanoclaw

COPY packages/agents/entrypoint.nanoclaw.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER agent
WORKDIR /nanoclaw
RUN npm install --frozen-lockfile 2>/dev/null || npm install
RUN npm run build

ENV ASSISTANT_NAME=@Andy

LABEL org.opencontainers.image.title="devlet-agent-nanoclaw"
LABEL org.opencontainers.image.description="NanoClaw agent + devlet base coding agents (claude-code, codex, opencode, pi, gemini)"
LABEL org.opencontainers.image.source="${REPOSITORY_URL}"
LABEL org.opencontainers.image.revision="${VCS_REF}"
LABEL org.opencontainers.image.created="${BUILD_DATE}"
LABEL org.opencontainers.image.version="${VERSION}"
LABEL devlet.agent.type="nanoclaw"

ENTRYPOINT ["/entrypoint.sh"]
CMD []
